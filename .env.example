# ─────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────
APP_NAME="AI Dental Booking Chatbot"
APP_VERSION="1.0.0"
DEBUG=true
# Backend log verbosity: DEBUG | INFO | WARNING | ERROR (see app/logging_config.py)
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-string-in-production
JWT_SECRET_KEY=change-this-jwt-secret-too
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─────────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────────
POSTGRES_USER=dental_user
POSTGRES_PASSWORD=dental_pass
POSTGRES_DB=dental_db
DATABASE_URL=postgresql+asyncpg://dental_user:dental_pass@localhost:5432/dental_db

# ─────────────────────────────────────────────────
# Redis (optional — backend hiện không gọi Redis; `docker compose` vẫn có service redis để dùng sau)
# ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────
# LLM Provider: "ollama" | "openai" | "openai_compatible"
# ─────────────────────────────────────────────────
LLM_PROVIDER=ollama

# Ollama (default - run locally via `ollama serve`)
OLLAMA_BASE_URL=http://localhost:11434
# Root Orchestrator - text-only, fast reasoning
ROOT_MODEL_NAME=qwen2.5:7b
# Dental Specialist — chat văn bản (cùng kiểu model text là đủ; có thể trùng ROOT nếu muốn)
SPECIALIST_MODEL_NAME=qwen2.5:7b
# If chat hangs at "classify_intent LLM invoke", raise read timeout or check Ollama (see /api/health/ollama)
OLLAMA_CONNECT_TIMEOUT=10
OLLAMA_READ_TIMEOUT=300
# Keep weights loaded between chat turns (reduces load_duration)
OLLAMA_KEEP_ALIVE=15m
# false = disable Qwen3.5 "thinking" mode (much faster; set true only if you need chain-of-thought)
OLLAMA_THINKING=false

# OpenAI (set LLM_PROVIDER=openai to use)
OPENAI_API_KEY=
OPENAI_ROOT_MODEL=gpt-4o-mini
OPENAI_SPECIALIST_MODEL=gpt-4o

# OpenAI-compatible endpoint (vLLM, Together.ai, LM Studio, etc.)
# Set LLM_PROVIDER=openai_compatible to use
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_ROOT_MODEL=qwen2.5:7b
OPENAI_COMPATIBLE_SPECIALIST_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────
# Langfuse Observability (optional)
# ─────────────────────────────────────────────────
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Langfuse self-hosted (docker-compose --profile langfuse up)
# LANGFUSE_HOST=http://localhost:3000
LANGFUSE_NEXTAUTH_SECRET=changeme
LANGFUSE_SALT=changeme

# ─────────────────────────────────────────────────
# File Upload
# ─────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ─────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────
# Development (allow all origins):
CORS_ORIGINS=["*"]
# Production (list explicit origins):
# CORS_ORIGINS=["https://your-domain.com","http://localhost:5500","http://127.0.0.1:5500"]
